# =====================================================================
# Arasaka Nexus — produção
# Copie para .env.prod e preencha. Esse arquivo NÃO entra no git.
# =====================================================================

# ---------- Django ----------
# Gere: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=PREENCHA_AQUI
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=nexus.arasaka.fun,localhost,127.0.0.1,backend,nexus-nginx
DJANGO_TIME_ZONE=America/Manaus
DJANGO_LOG_LEVEL=INFO

# Cloudflare termina TLS na borda; o tráfego interno é HTTP.
# Mantém SECURE_PROXY_SSL_HEADER pra Django saber que o request original era HTTPS.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_HSTS_SECONDS=31536000

# Cloudflare envia X-Forwarded-Proto e o usuário acessa via HTTPS.
DJANGO_CORS_ALLOWED_ORIGINS=https://nexus.arasaka.fun

# ---------- Database (postgres-global) ----------
# Provisionado segundo deploy/DEPLOY.md
DB_NAME=nexus
DB_USER=nexus
DB_PASSWORD=PREENCHA_AQUI
DB_HOST=postgres-global
DB_PORT=5432

# ---------- JWT ----------
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ---------- Celery / Redis ----------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# ---------- MangaDex ----------
MANGADEX_USER_AGENT=ArasakaNexus/1.0 (+https://nexus.arasaka.fun; pitohuikun@gmail.com)
MANGADEX_BASE_URL=https://api.mangadex.org
MANGADEX_GLOBAL_RATE_PER_SECOND=4
MANGADEX_AT_HOME_RATE_PER_MINUTE=35
MANGADEX_AT_HOME_CACHE_SECONDS=600
MANGADEX_REQUEST_TIMEOUT=20
PAGE_MIRROR_TTL_DAYS=30

# ---------- Nginx / network ----------
# Porta exposta no host. Cloudflare → http://localhost:8400
NEXUS_HTTP_PORT=8400

# Nome da rede docker EXTERNA do postgres-global. Confirme com:
#   docker inspect postgres-global -f '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{end}}'
POSTGRES_NETWORK=postgres-global_default

# ---------- Web Push (notificacoes de capitulo novo) ----------
# Gere as 3 chaves UMA VEZ por ambiente:
#   docker compose -f docker-compose.prod.yml exec backend \
#     python manage.py generate_vapid
# Cola a saida nas 3 vars abaixo + NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# Backup em cofre — re-gerar invalida subscriptions de todos os usuarios.
VAPID_PRIVATE_KEY=PREENCHA_APOS_GENERATE_VAPID
VAPID_PUBLIC_KEY=PREENCHA_APOS_GENERATE_VAPID
VAPID_SUBJECT=mailto:contact@arasaka.fun
PUSH_NEW_CHAPTER_MAX_AGE_HOURS=24

# ---------- Cloudflare Turnstile ----------
# Crie um widget em https://dash.cloudflare.com/?to=/:account/turnstile
# Domain: nexus.arasaka.fun (ou * pra testes). Mode: managed.
# Secret Key fica aqui (backend valida); Site Key vai pro frontend abaixo.
TURNSTILE_SECRET_KEY=PREENCHA_AQUI
TURNSTILE_TIMEOUT=5

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=https://nexus.arasaka.fun/api
# Site Key publica do widget Turnstile. Sem isso, o widget nao renderiza
# (modo dev) e o backend tambem aceita sem validar (TURNSTILE_SECRET_KEY
# vazio). Pra prod, preencha as duas.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=PREENCHA_AQUI
# Public VAPID key (mesma string da VAPID_PUBLIC_KEY acima — frontend
# precisa dela em build-time pra subscribe() funcionar).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=PREENCHA_APOS_GENERATE_VAPID

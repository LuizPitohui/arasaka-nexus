postgres_data/
.docker/

# ========================
# BACKEND (Python / Django)
# ========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / Packaging
backend/build/
backend/dist/
backend/*.egg-info/
backend/MANIFEST

# Virtual Environments & Dependency Managers
backend/.venv/
backend/.poetry/
venv/
env/
.python-version
poetry.lock  # (Opcional: em projetos profissionais, recomenda-se subir o lock)

# Database local (caso use sqlite para testes)
backend/db.sqlite3
backend/db.sqlite3-journal
media/

# Django Media (A estratégia correta)
# Ignoramos todas as fotos enviadas, mas mantemos a pasta estrutural
backend/media/employee_photos/*
!backend/media/employee_photos/.gitkeep

# ========================
# FRONTEND (Node / Next.js)
# ========================
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js

# Next.js Build & Cache
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts

# Logs de Erro do Node
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.turbo
# ===================================================================
# Arasaka Nexus - Environment Variables
# Copie este arquivo para .env e preencha com os valores corretos.
# NUNCA versione o arquivo .env real.
# ===================================================================

# --- Django Core ---
# Gere uma chave nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=troque-isto-em-producao
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/Manaus
DJANGO_LOG_LEVEL=INFO

# Em produção (DEBUG=0), liga HSTS e SSL redirect — desligue só atrás de proxy local sem TLS
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_HSTS_SECONDS=31536000

# --- CORS (origens permitidas no frontend, separadas por vírgula) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database (PostgreSQL) ---
DB_NAME=arasaka
DB_USER=arasaka
DB_PASSWORD=troque-isto
DB_HOST=db
DB_PORT=5432

# Compatibilidade com docker-compose (usa as mesmas vars como POSTGRES_*)
POSTGRES_DB=${DB_NAME}
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}

# --- JWT ---
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# --- MangaDex Client ---
# Identificação obrigatória — substitua pelo seu domínio/email real
MANGADEX_USER_AGENT=ArasakaNexus/0.1 (+https://github.com/SEU-USUARIO/arasaka-nexus)
MANGADEX_BASE_URL=https://api.mangadex.org
# Limite global (a API permite ~5/s; mantemos folga)
MANGADEX_GLOBAL_RATE_PER_SECOND=4
# /at-home/server tem teto de 40/min; usamos 35 para segurança
MANGADEX_AT_HOME_RATE_PER_MINUTE=35
# TTL do cache do endpoint /at-home/server
MANGADEX_AT_HOME_CACHE_SECONDS=600
MANGADEX_REQUEST_TIMEOUT=20
